{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/.well-known/mcp.json",
      "rewrite": "/.well-known/mcp.json",
      "headers": {
        "Content-Type": "application/json",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "route": "/sales-assistant",
      "rewrite": "/sales-assistant.html"
    },
    {
      "route": "/mirrors",
      "rewrite": "/bc-open-mirror.html"
    },
    {
      "route": "/claude-mcp-chat",
      "rewrite": "/claude-mcp-chat.html"
    },
    {
      "route": "/api-key-settings",
      "rewrite": "/api-key-settings.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.html", "/api/*", "/.well-known/*"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
